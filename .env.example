# AOCG AI Офис — бэкенд · шаблон переменных окружения
# Скопировать в .env для локальной разработки и заполнить значения.
# Реальные значения в продакшене хранятся в Railway → Variables.
# Файл .env НИКОГДА не коммитить (он в .gitignore). Этот .env.example — коммитить можно, в нём нет секретов.

# --- База данных ---
DATABASE_URL=                      # Railway выдаёт автоматически

# --- Авторизация (JWT) ---
JWT_SECRET_KEY=                    # случайная строка 64 символа
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Email (SendPulse) ---
SENDPULSE_API_USER_ID=
SENDPULSE_API_SECRET=

# --- ИНН → ЕГРЮЛ (DaData) ---
DADATA_API_KEY=

# --- ФНС проверка чеков ---
PROVERKACHEKA_TOKEN=

# --- AI (Anthropic, OCR) ---
ANTHROPIC_API_KEY=

# --- OAuth провайдеры ---
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MAILRU_CLIENT_ID=
MAILRU_CLIENT_SECRET=

# --- Файловое хранилище (S3-совместимое: Cloudflare R2 / Yandex Object Storage) ---
STORAGE_ENDPOINT=
STORAGE_BUCKET=aocg-receipts
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=auto

# --- Альфа-Банк ---
ALFABANK_CLIENT_ID=
ALFABANK_CLIENT_SECRET=

# --- Конфигурация ---
APP_URL=https://aocgaiofficeweb.up.railway.app
CORS_ORIGINS=https://aocgaiofficeweb.up.railway.app
ENVIRONMENT=production
MAX_UPLOAD_SIZE_MB=5
PRIVACY_POLICY_VERSION=1.0
# Sentry DSN для отлова ошибок. Пусто → Sentry выключен (как RESEND_API_KEY).
SENTRY_DSN=
# Окружение для Sentry: production / staging / local
ENVIRONMENT=production
