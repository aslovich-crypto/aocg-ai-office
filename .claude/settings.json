{
  "permissions": {
    "allow": [
      "Bash(git log *)",
      "Bash(git rev-list *)",
      "Bash(git --no-pager diff *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git --no-pager show *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git stash list)",
      "Bash(ls *)",
      "Bash(rg *)",
      "Bash(./venv/bin/python -m pytest *)",
      "Bash(./venv/bin/pip list *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf*)",
      "Bash(rm -fr*)",
      "Bash(*DROP TABLE*)",
      "Bash(*DROP INDEX*)",
      "Bash(*DROP DATABASE*)",
      "Bash(*DELETE FROM*)",
      "Bash(*TRUNCATE*)",
      "Bash(dropdb*)",
      "Bash(git clean*)",
      "Bash(railway down*)",
      "Bash(railway redeploy*)",
      "Bash(railway up*)",
      "Bash(sudo*)",
      "Bash(curl* | sh*)",
      "Bash(curl* | bash*)",
      "Bash(wget* | sh*)",
      "Bash(wget* | bash*)",
      "Bash(chmod -R*)",
      "Bash(chown -R*)",
      "Edit(**/.env)",
      "Write(**/.env)",
      "Read(**/.ssh/**)",
      "Read(**/.aws/**)",
      "Read(**/id_rsa*)",
      "Read(**/.pgpass)",
      "Read(**/.npmrc)",
      "Read(**/credentials*)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)"
    ],
    "ask": [
      "Bash(git checkout .*)",
      "Bash(git checkout -- *)",
      "Bash(git restore*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-/Users/alekseishukalovich/aocg-ai-office}/.claude/hooks/block-prod-db.sh\"",
            "statusMessage": "Проверка на деструктив прод-БД"
          }
        ]
      }
    ]
  }
}
